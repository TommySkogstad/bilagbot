# Valgfri: Override modell (default: bruker Claude CLI sin standardmodell)
# CLAUDE_MODEL=claude-sonnet-4-6

# Claude CLI timeout i sekunder (default: 180)
# CLAUDE_CLI_TIMEOUT=180

# Fiken API
FIKEN_API_TOKEN=
FIKEN_COMPANY_SLUG=

# Fiken HTTP-timeout i sekunder (default: 30)
# FIKEN_HTTP_TIMEOUT=30

# Fiken retry-konfigurasjon
# FIKEN_MAX_RETRIES=3
# FIKEN_RETRY_BACKOFF=2

# Cloudflare Tunnel
CLOUDFLARE_TUNNEL_TOKEN=

# HTTP Basic Auth for web-UI og API (valgfri).
# Aktiveres kun når BEGGE er satt. Uten disse er web-UI åpent.
# AUTH_USER=admin
# AUTH_PASS=hemmelighord

# Antall godkjenninger før en leverandør får auto-approve (default: 3)
# AUTO_APPROVE_THRESHOLD=3

# Valgfri: Override modell (default: bruker Claude CLI sin standardmodell)
# CLAUDE_MODEL=claude-sonnet-4-5-20250514

# Claude CLI timeout i sekunder (default: 180)
# CLAUDE_CLI_TIMEOUT=180

# Fiken API
FIKEN_API_TOKEN=
FIKEN_COMPANY_SLUG=

# Fiken HTTP-timeout i sekunder (default: 30)
# FIKEN_HTTP_TIMEOUT=30

# Fiken retry-konfigurasjon
# FIKEN_MAX_RETRIES=3
# FIKEN_RETRY_BACKOFF=2

# Cloudflare Tunnel
CLOUDFLARE_TUNNEL_TOKEN=
